# Coding style settings for any editor that supports EditorConfig.
# Reference: https://editorconfig.org

root = true

# Defaults applied to every file in the repository.
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# YAML (workflows, action.yml) uses 2-space indentation by convention.
[*.{yml,yaml}]
indent_size = 2

# Markdown allows trailing whitespace as a hard line break.
[*.md]
trim_trailing_whitespace = false
